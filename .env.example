# Copy this file to .env and fill in. Never commit .env itself.
#
# This project uses any OpenAI-compatible API. Pick one backend below:
#
#   OpenRouter (free tier, recommended for dev):
#     LLM_BASE_URL=https://openrouter.ai/api/v1
#     LLM_MODEL=deepseek/deepseek-chat-v3:free
#
#   DeepSeek direct:
#     LLM_BASE_URL=https://api.deepseek.com/v1
#     LLM_MODEL=deepseek-chat
#
#   Ollama (local):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_MODEL=llama3.1:8b
#
#   Anthropic (via openai-compat proxy, if needed):
#     See Anthropic docs for openai-sdk compatibility setup

LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat-v3:free
LLM_FALLBACK_ENABLED=true
